# Whitelist repo: $HOME is the repo root, so everything is ignored by default
# and tracked paths are re-included below. A file can only be re-included if
# every parent directory is re-included first, hence the !dir/ + dir/* + !file
# chains for directories that also hold untracked content.
/*

# --- top-level files ---
!/.gitignore
!/.bash_profile
!/.bashrc
!/.profile
!/.zshenv

# .claude: only the global CLAUDE.md is tracked
!/.claude/
/.claude/*
!/.claude/CLAUDE.md

# --- .config ---
!/.config/
/.config/*
!/.config/CLAUDE.md
!/.config/starship.toml

# Config directories tracked wholesale
!/.config/ack/
!/.config/ag/
!/.config/atuin/
!/.config/bash/
!/.config/bat/
!/.config/bundle/
!/.config/ctags/
!/.config/gem/
!/.config/git/
!/.config/ideavim/
!/.config/irb/
!/.config/keyd/
!/.config/kitty/
!/.config/linearmouse/
!/.config/pry/
!/.config/psql/
!/.config/rails/
!/.config/razorjack/
!/.config/readline/
!/.config/ripgrep/
!/.config/scripts/
!/.config/shell/
!/.config/tmux/

# Config directories tracked selectively (they also hold untracked content)

# environment.d: only the ydotool socket path is ours; the rest is runtime.
!/.config/environment.d/
/.config/environment.d/*
!/.config/environment.d/ydotool.conf

# ghostty: the ##os.Linux alternates are tracked; the plain-name symlinks yadm
# generates from them stay ignored via the /* rule.
!/.config/ghostty/
/.config/ghostty/*
!/.config/ghostty/config
!/.config/ghostty/linux.conf##os.Linux
!/.config/ghostty/ghostty-linux.css##os.Linux

!/.config/jesseduffield/
/.config/jesseduffield/*
!/.config/jesseduffield/lazygit/
/.config/jesseduffield/lazygit/*
!/.config/jesseduffield/lazygit/config.yml

!/.config/karabiner/
/.config/karabiner/*
!/.config/karabiner/karabiner.json

!/.config/mise/
/.config/mise/*
!/.config/mise/config.toml

!/.config/nvim/
/.config/nvim/*
!/.config/nvim/.gitignore
!/.config/nvim/init.lua
!/.config/nvim/lazy-lock.json
!/.config/nvim/lazyvim.json
!/.config/nvim/stylua.toml
!/.config/nvim/lua/

!/.config/vim/
/.config/vim/*
!/.config/vim/vimrc
!/.config/vim/colors/

# systemd user units: only ydotoold is ours; voxtype et al. write units here too.
!/.config/systemd/
/.config/systemd/*
!/.config/systemd/user/
/.config/systemd/user/*
!/.config/systemd/user/ydotoold.service

# voxtype: track only the config; it also stores downloaded Whisper models here
!/.config/voxtype/
/.config/voxtype/*
!/.config/voxtype/config.toml

# yadm: track only the bootstrap; yadm keeps its machine-local config here too.
!/.config/yadm/
/.config/yadm/*
!/.config/yadm/bootstrap

!/.config/zsh/
/.config/zsh/.zcompdump*
/.config/zsh/.zsh_sessions/

!/.config/zellij/
/.config/zellij/*
!/.config/zellij/config.kdl
!/.config/zellij/layouts/

# --- .local: only hand-written scripts, not installed binaries/symlinks ---
!/.local/
/.local/*
!/.local/bin/
/.local/bin/*
!/.local/bin/yadm
!/.local/bin/za

# kitty is tracked wholesale, so ignore the plain name yadm links to the
# ##os.Linux alternate on Linux (yadm also auto-excludes generated links via
# repo.git/info/exclude; this guards the plain-git clone in ~/Projects too).
/.config/kitty/linux-local.conf

# keyd-application-mapper writes these into its config dir at runtime; keyd's
# dir is tracked wholesale, so re-ignore them.
/.config/keyd/app.lock
/.config/keyd/app.log
