# Whitelist repo: $HOME is the repo root, so everything is ignored by default
# and tracked paths are re-included below. A file can only be re-included if
# every parent directory is re-included first, hence the !dir/ + dir/* + !file
# chains for directories that also hold untracked content.
/*

# --- top-level files ---
!/.gitignore
!/.bash_profile
!/.bashrc
!/.profile
!/.zshenv

# --- top-level directories ---
!/.zsh/

# .claude: only the global CLAUDE.md is tracked
!/.claude/
/.claude/*
!/.claude/CLAUDE.md

# VS Code user settings (dropped together with the app later)
!/Library/
/Library/*
!/Library/Application Support/
/Library/Application Support/*
!/Library/Application Support/Code/
/Library/Application Support/Code/*
!/Library/Application Support/Code/User/
/Library/Application Support/Code/User/*
!/Library/Application Support/Code/User/settings.json
!/Library/Application Support/Code/User/keybindings.json

# --- .config ---
!/.config/
/.config/*
!/.config/CLAUDE.md

# Config directories tracked wholesale
!/.config/ack/
!/.config/ag/
!/.config/atuin/
!/.config/bash/
!/.config/bat/
!/.config/bundle/
!/.config/ctags/
!/.config/gem/
!/.config/git/
!/.config/ideavim/
!/.config/irb/
!/.config/kitty/
!/.config/linearmouse/
!/.config/pry/
!/.config/psql/
!/.config/rails/
!/.config/ranger/
!/.config/razorjack/
!/.config/readline/
!/.config/ripgrep/
!/.config/scripts/
!/.config/tmux/

# Config directories tracked selectively (they also hold untracked content)
!/.config/ghostty/
/.config/ghostty/*
!/.config/ghostty/config

!/.config/jesseduffield/
/.config/jesseduffield/*
!/.config/jesseduffield/lazygit/
/.config/jesseduffield/lazygit/*
!/.config/jesseduffield/lazygit/config.yml

!/.config/karabiner/
/.config/karabiner/*
!/.config/karabiner/karabiner.json

!/.config/mise/
/.config/mise/*
!/.config/mise/config.toml

!/.config/nvim/
/.config/nvim/*
!/.config/nvim/.gitignore
!/.config/nvim/init.lua
!/.config/nvim/lazy-lock.json
!/.config/nvim/lazyvim.json
!/.config/nvim/stylua.toml
!/.config/nvim/lua/

!/.config/vim/
/.config/vim/*
!/.config/vim/vimrc
!/.config/vim/colors/

!/.config/zsh/
/.config/zsh/.zcompdump*
/.config/zsh/.zsh_sessions/

!/.config/zellij/
/.config/zellij/*
!/.config/zellij/config.kdl
!/.config/zellij/layouts/

# --- .local: only hand-written scripts, not installed binaries/symlinks ---
!/.local/
/.local/*
!/.local/bin/
/.local/bin/*
!/.local/bin/za
