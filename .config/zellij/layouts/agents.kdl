layout {
    default_tab_template {
        pane split_direction="vertical" {
            pane size=20 borderless=true {
                plugin location="file:~/.config/zellij/plugins/zellij-vertical-tabs.wasm"
            }
            children
        }
    }

    tab name="shell" focus=true {
        pane
    }

    tab name="agent-1" {
        pane
    }

    tab name="agent-2" {
        pane
    }
}
