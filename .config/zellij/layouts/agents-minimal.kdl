layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        children
    }

    tab name="shell" focus=true {
        pane
    }

    tab name="agent-1" {
        pane
    }

    tab name="agent-2" {
        pane
    }
}
