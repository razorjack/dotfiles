font-family = "Monaspace Neon"
font-size = 15
font-feature = -calt, -liga, -dlig

adjust-cell-height = 20%
adjust-cell-width  = 0%

background = #0c0c0d
foreground = #d3d2d1
selection-background = #163356
selection-foreground = #b3b1ad
cursor-color = #73b7f2

# palette = 0=#484f58
# palette = 1=#ff7b72
