# palette = 10=#56d364
# palette = 11=#e3b341
# palette = 12=#79c0ff
# palette = 13=#d2a8ff
# palette = 14=#56d4dd
# palette = 15=#b3b1ad

split-divider-color = #b3b1ad
cursor-style-blink = false
cursor-opacity = 1.0
# Solid block cursor (drawn in cursor-color above). Ghostty's shell integration
# otherwise forces a thin bar at the shell prompt - the "dim pipe" - so disable
# just that feature (no-cursor) and keep the rest (title, sudo).
cursor-style = block
shell-integration-features = no-cursor

macos-titlebar-style = tabs
keybind = shift+enter=text:\x1b\r

# Linux/KDE-only overrides live in linux.conf, a yadm alternate: on Linux yadm
# links it to linux.conf##os.Linux (smaller font-size for fractional scaling,
# window-decoration tweaks); on macOS the link doesn't exist, so this optional
# include is a no-op there and the mac config is untouched. Last include wins,
# so its font-size overrides the one above on Linux.
config-file = ?linux.conf
